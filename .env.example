# Copy to .env for local Taskfile development and Docker Compose.
# Replace every placeholder before running the app.

# Required for the Go API. Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-48-random-bytes-from-openssl-rand-base64-48

# Required for all agent features. The Go API and Python agent must share this exact value.
# Generate with: openssl rand -base64 48
AGENT_INTERNAL_SERVICE_TOKEN=replace-with-48-random-bytes-shared-by-api-and-agent

# Required when GIN_MODE=release. Use your reverse-proxy IP/CIDR, or "none" only when no proxy is present.
TRUSTED_PROXIES=none

# Production/passkey deployments should set these explicitly.
# WEBAUTHN_RP_ID=coins.example.com
# WEBAUTHN_ORIGIN=https://coins.example.com
# CORS_ORIGINS=https://coins.example.com

# Multi-container deployments should keep Docker service names here.
# AGENT_SERVICE_URL=http://agent:8081
# AGENT_INTERNAL_CALLBACK_URL=http://app:8080
# AGENT_TRUSTED_OUTBOUND_ORIGINS=http://app:8080

# Local development with task up-all can use localhost callback URLs.
# AGENT_SERVICE_URL=http://localhost:8081
# AGENT_INTERNAL_CALLBACK_URL=http://localhost:8080
# AGENT_TRUSTED_OUTBOUND_ORIGINS=http://localhost:8080
# AGENT_ALLOW_LOCAL_OUTBOUND=true
